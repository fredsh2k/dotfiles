#!/usr/bin/env zsh
set -euo pipefail

repo="$HOME/Code/GitHub/copilot-agent-runtime"
entry="$repo/dist-cli/index.js"
app="$repo/dist-cli/app.js"

if [[ ! -f "$entry" || ! -f "$app" ]]; then
  print -u2 "copilot: local CLI build is missing. Run: copilot-build"
  exit 1
fi

source "$HOME/.cargo/env"
exec node --enable-source-maps --report-on-fatalerror "$entry" "$@"
