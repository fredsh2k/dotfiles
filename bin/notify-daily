#!/usr/bin/env python3
"""
Nightly Discord briefing: upcoming Google Calendar events + Tasks status.

Secrets resolution (env first, then file fallback):
  DISCORD_WEBHOOK         | ~/.config/secrets/discord-webhook
  GOOGLE_OAUTH_CLIENT     | ~/.config/secrets/google-oauth-client.json
  GOOGLE_OAUTH_TOKEN      | ~/.config/secrets/google-oauth-token.json

In CI (GHA), env vars carry the JSON content directly — no files needed.
Locally, falls back to files in ~/.config/secrets/.

If TARGET_HOUR env var is set (used in CI to handle DST), the script exits 0
when the current local hour doesn't match. This lets us schedule the workflow
at multiple UTC times to cover DST transitions.
"""

from __future__ import annotations

import os
import sys
import json
import datetime as dt
from pathlib import Path
from typing import Iterable
from zoneinfo import ZoneInfo

import urllib.request
import urllib.error

from google.auth.transport.requests import Request
from google.oauth2.credentials import Credentials
from google_auth_oauthlib.flow import InstalledAppFlow
from googleapiclient.discovery import build

SECRETS = Path.home() / ".config" / "secrets"
CLIENT_FILE = SECRETS / "google-oauth-client.json"
TOKEN_FILE = SECRETS / "google-oauth-token.json"
WEBHOOK_FILE = SECRETS / "discord-webhook"

SCOPES = [
    "https://www.googleapis.com/auth/calendar.readonly",
    "https://www.googleapis.com/auth/tasks.readonly",
]

LOCAL_TZ = ZoneInfo("Asia/Jerusalem")  # adjust if you move
DISCORD_LIMIT = 1900


def _load_secret(env_name: str, file_path: Path) -> str:
    """Return secret content from env var if set, else file content."""
    val = os.environ.get(env_name)
    if val is not None and val.strip():
        return val
    if file_path.exists():
        return file_path.read_text()
    sys.exit(f"missing secret: env {env_name} unset and {file_path} not found")


def get_credentials() -> Credentials:
    # Prefer env vars (CI), fall back to files (local).
    token_env = os.environ.get("GOOGLE_OAUTH_TOKEN")
    client_env = os.environ.get("GOOGLE_OAUTH_CLIENT")

    creds: Credentials | None = None

    if token_env and token_env.strip():
        creds = Credentials.from_authorized_user_info(json.loads(token_env), SCOPES)
    elif TOKEN_FILE.exists():
        creds = Credentials.from_authorized_user_file(str(TOKEN_FILE), SCOPES)

    if creds and creds.valid:
        return creds

    if creds and creds.expired and creds.refresh_token:
        creds.refresh(Request())
        # Persist locally only; in CI we can't write back.
        if not token_env and TOKEN_FILE.parent.exists():
            TOKEN_FILE.write_text(creds.to_json())
            TOKEN_FILE.chmod(0o600)
        return creds

    # Need to do OAuth flow — only possible locally.
    if client_env and client_env.strip():
        sys.exit("token expired and no refresh available; cannot run interactive OAuth in CI")
    if not CLIENT_FILE.exists():
        sys.exit(f"missing {CLIENT_FILE} — download OAuth client JSON from Google Cloud Console")
    flow = InstalledAppFlow.from_client_secrets_file(str(CLIENT_FILE), SCOPES)
    creds = flow.run_local_server(port=0)
    TOKEN_FILE.write_text(creds.to_json())
    TOKEN_FILE.chmod(0o600)
    return creds



def fetch_events(creds: Credentials, days: int = 7) -> list[dict]:
    service = build("calendar", "v3", credentials=creds, cache_discovery=False)
    now = dt.datetime.now(tz=LOCAL_TZ)
    end = now + dt.timedelta(days=days)
    resp = service.events().list(
        calendarId="primary",
        timeMin=now.isoformat(),
        timeMax=end.isoformat(),
        singleEvents=True,
        orderBy="startTime",
        maxResults=100,
    ).execute()
    return resp.get("items", [])


def fetch_tasks(creds: Credentials) -> list[dict]:
    service = build("tasks", "v1", credentials=creds, cache_discovery=False)
    # Default list = "@default"
    resp = service.tasks().list(
        tasklist="@default",
        showCompleted=False,
        showHidden=False,
        maxResults=100,
    ).execute()
    return resp.get("items", [])


def parse_event_start(ev: dict) -> tuple[dt.datetime, bool]:
    start = ev.get("start", {})
    if "dateTime" in start:
        return dt.datetime.fromisoformat(start["dateTime"]).astimezone(LOCAL_TZ), False
    if "date" in start:
        d = dt.date.fromisoformat(start["date"])
        return dt.datetime.combine(d, dt.time.min, tzinfo=LOCAL_TZ), True
    return dt.datetime.max.replace(tzinfo=LOCAL_TZ), False


def format_events(events: Iterable[dict]) -> str:
    by_day: dict[dt.date, list[str]] = {}
    for ev in events:
        start, all_day = parse_event_start(ev)
        title = ev.get("summary", "(no title)")
        if all_day:
            line = f"  • {title} _(all-day)_"
        else:
            line = f"  • {start.strftime('%H:%M')} {title}"
        by_day.setdefault(start.date(), []).append(line)

    if not by_day:
        return "_No events in the next 7 days._"

    today = dt.date.today()
    out = []
    for day in sorted(by_day):
        delta = (day - today).days
        if delta == 0:
            label = "Today"
        elif delta == 1:
            label = "Tomorrow"
        else:
            label = day.strftime("%a %b %d")
        out.append(f"**{label}**")
        out.extend(by_day[day])
    return "\n".join(out)


def format_tasks(tasks: list[dict]) -> str:
    today = dt.date.today()
    overdue: list[tuple[dt.date | None, str]] = []
    due_today: list[tuple[dt.date | None, str]] = []
    upcoming: list[tuple[dt.date | None, str]] = []
    no_date: list[tuple[dt.date | None, str]] = []

    for t in tasks:
        title = t.get("title", "(untitled)")
        due_str = t.get("due")  # RFC3339, date-only semantics
        if not due_str:
            no_date.append((None, title))
            continue
        try:
            due = dt.datetime.fromisoformat(due_str.replace("Z", "+00:00")).date()
        except ValueError:
            no_date.append((None, title))
            continue

        if due < today:
            overdue.append((due, title))
        elif due == today:
            due_today.append((due, title))
        else:
            upcoming.append((due, title))

    if not (overdue or due_today or upcoming or no_date):
        return "_No open tasks._"

    sections = []

    def render(label: str, items: list[tuple[dt.date | None, str]], with_date: bool = True):
        if not items:
            return
        sections.append(f"**{label}**")
        for due, title in sorted(items, key=lambda x: (x[0] or dt.date.max)):
            if with_date and due:
                sections.append(f"  • `{due.isoformat()}` {title}")
            else:
                sections.append(f"  • {title}")

    render(f"Overdue ({len(overdue)})", overdue)
    render(f"Due today ({len(due_today)})", due_today)
    render(f"Upcoming ({len(upcoming)})", upcoming)
    render(f"No due date ({len(no_date)})", no_date, with_date=False)

    return "\n".join(sections)


def post_discord(content: str) -> None:
    webhook = _load_secret("DISCORD_WEBHOOK", WEBHOOK_FILE).strip()
    content = content[:DISCORD_LIMIT]
    body = json.dumps({"content": content}).encode()
    req = urllib.request.Request(
        webhook,
        data=body,
        headers={
            "Content-Type": "application/json",
            "User-Agent": "notify-daily (https://github.com/fredsh2k/dotfiles, 1.0)",
        },
        method="POST",
    )
    try:
        with urllib.request.urlopen(req, timeout=10) as r:
            r.read()
    except urllib.error.HTTPError as e:
        sys.exit(f"discord webhook error: {e.code} {e.read().decode(errors='replace')}")


def main() -> None:
    # DST guard: in CI we schedule at multiple UTC times; only one matches local TARGET_HOUR.
    target_hour = os.environ.get("TARGET_HOUR")
    if target_hour and target_hour != "skip":
        now_local = dt.datetime.now(tz=LOCAL_TZ)
        if now_local.hour != int(target_hour):
            print(f"local hour {now_local.hour} != TARGET_HOUR {target_hour}, skipping")
            return

    creds = get_credentials()
    events = fetch_events(creds, days=7)
    tasks = fetch_tasks(creds)

    today_str = dt.datetime.now(tz=LOCAL_TZ).strftime("%a %b %d")
    parts = [
        f"## 🌙 Nightly briefing — {today_str}",
        "",
        "### 📅 Calendar (next 7 days)",
        format_events(events),
        "",
        "### ✅ Tasks",
        format_tasks(tasks),
    ]
    content = "\n".join(parts)

    # Split into chunks if over Discord limit
    if len(content) <= DISCORD_LIMIT:
        post_discord(content)
        return

    # Naive chunking by section
    chunks: list[str] = []
    current = ""
    for line in content.splitlines(keepends=True):
        if len(current) + len(line) > DISCORD_LIMIT:
            chunks.append(current)
            current = ""
        current += line
    if current:
        chunks.append(current)

    for c in chunks:
        post_discord(c)


if __name__ == "__main__":
    main()
