layout {
    default_tab_template {
        children
        pane size=2 borderless=true {
            plugin location="status-bar"
        }
    }

    tab name="dev" focus=true {
        pane split_direction="vertical" {
            pane size="20%" name="opencode" focus=true command="zsh" {
                args "-c" "source ~/.zshrc && sleep 2 && opencode-tui"
            }
            pane size="60%" name="vim1" focus=true
            pane size="20%" name="term1" command="zsh" {
                args "-c" "source ~/.zshrc && opencode-start"
            }
        }
    }
}
