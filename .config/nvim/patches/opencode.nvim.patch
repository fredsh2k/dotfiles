diff --git a/lua/opencode/cli/server.lua b/lua/opencode/cli/server.lua
index aba7490..9b5ae57 100644
--- a/lua/opencode/cli/server.lua
+++ b/lua/opencode/cli/server.lua
@@ -139,8 +139,12 @@ function M.get(launch)
       if #servers_in_cwd == 1 then
         -- User most likely wants to connect to the single server in their CWD
         return servers_in_cwd[1]
+      elseif #servers_in_cwd > 1 then
+        -- Multiple CWD matches (e.g. "~" matches everything) - pick the most specific one
+        table.sort(servers_in_cwd, function(a, b) return #a.cwd > #b.cwd end)
+        return servers_in_cwd[1]
       else
-        -- Can't guess which one the user wants based on CWD - select from *all*
+        -- No CWD match at all - let the user pick from all servers
         return require("opencode.ui.select_server").select_server(servers)
       end
     end)
diff --git a/lua/opencode/context.lua b/lua/opencode/context.lua
index d2a5c26..13b6ea0 100644
--- a/lua/opencode/context.lua
+++ b/lua/opencode/context.lua
@@ -17,6 +17,9 @@ local ns_id = vim.api.nvim_create_namespace("OpencodeContext")
 ---Returns the filename for a buffer if it has one, else nil.
 ---@param buf number
 local function get_filename(buf)
+  if not vim.api.nvim_buf_is_valid(buf) then
+    return nil
+  end
   if vim.api.nvim_get_option_value("buftype", { buf = buf }) == "" then
     local name = vim.api.nvim_buf_get_name(buf)
     if name ~= "" then
@@ -85,6 +88,13 @@ local function highlight(buf, range)
     local line = vim.api.nvim_buf_get_lines(buf, end_row, end_row + 1, false)[1] or ""
     end_col = math.min(range.to[2] + 1, #line)
   end
+  -- Guard: skip highlight if range is out of bounds for this buffer.
+  -- This can happen when selection marks come from a different window/buffer
+  -- (e.g. a snacks picker list) than the last-used valid window's buffer.
+  local line_count = vim.api.nvim_buf_line_count(buf)
+  if range.from[1] - 1 >= line_count or end_row >= line_count then
+    return
+  end
   vim.api.nvim_buf_set_extmark(buf, ns_id, range.from[1] - 1, range.from[2], {
     end_row = end_row,
     end_col = end_col,
@@ -115,7 +125,9 @@ function Context.new(range)
 end
 
 function Context:clear()
-  vim.api.nvim_buf_clear_namespace(self.buf, ns_id, 0, -1)
+  if vim.api.nvim_buf_is_valid(self.buf) then
+    vim.api.nvim_buf_clear_namespace(self.buf, ns_id, 0, -1)
+  end
 end
 
 function Context:resume()
