{
  "$schema": "https://opencode.ai/config.json",
  "model": "github-copilot/gpt-5.5",
  "shell": "/bin/zsh",
  "permission": "allow",
  "plugin": ["/Users/fsherman/Code/Personal/dotfiles/.config/opencode/superpowers"],
  "lsp": {
    "puppet": {
      "command": [
        "puppet-languageserver",
        "--stdio"
      ],
      "env": {
        "RBENV_VERSION": "3.4.6"
      },
      "extensions": [".pp", ".epp"]
    }
  },
  "mcp": {
    "datadog": {
      "type": "remote",
      "url": "https://mcp.datadoghq.com/api/unstable/mcp-server/mcp?toolsets=all",
      "enabled": true
    },
    "sentry": {
      "type": "remote",
      "url": "https://mcp.sentry.dev/mcp",
      "enabled": true,
      "oauth": {}
    },
    "slack": {
      "type": "remote",
      "url": "https://mcp.slack.com/mcp",
      "enabled": true,
      "oauth": {
        "clientId": "12348411142.11062036567072"
      }
    },
    "kusto": {
      "type": "local",
      "command": ["npx", "-y", "kusto-mcp@latest"],
      "enabled": true,
      "environment": {
        "KUSTO_DEFAULT_CLUSTER": "https://gh-analytics.eastus.kusto.windows.net",
        "KUSTO_DEFAULT_DATABASE": "hydro"
      }
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest",
        "--browser=chrome",
        "--user-data-dir=/Users/fsherman/.chrome-agent-profile"
      ],
      "enabled": true
    },
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--browser-url=http://127.0.0.1:9222",
        "--no-usage-statistics"
      ],
      "enabled": true,
      "environment": {
        "CHROME_DEVTOOLS_MCP_NO_UPDATE_CHECKS": "true"
      }
    }
  },
  "provider": {
    "ollama": {
      "models": {
        "gemma4": {
          "name": "gemma4"
        }
      },
      "name": "Ollama",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      }
    }
  }
}
